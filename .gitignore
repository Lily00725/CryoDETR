**/__pycache__/
*.py[cod]
*$py.class

# =========================
# Jupyter cache
# =========================
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# =========================
# Build / install artifacts
# =========================
build/
**/build/
dist/
**/dist/
*.egg-info/
**/*.egg-info/
.eggs/
*.egg

# Compiled extension / object files
*.so
*.pyd
*.dll
*.o
*.obj

# =========================
# Virtual environments
# =========================
venv/
env/
.venv/
ENV/
conda_env/

